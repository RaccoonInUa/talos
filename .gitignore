# ./.gitignore
# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
eggs/
*.egg-info/
pip-wheel-metadata/
wheelhouse/

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Editor / IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checkers / caches
.mypy_cache/
.pyright/
pyrightconfig.* 

# Sensitive / env
.env
.env.* 
*.pem
*.key

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Node / frontend (if present)
node_modules/

# Misc
*.db
*.sqlite3